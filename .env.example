DROPBOX_APP_KEY=your_app_key_here
DROPBOX_APP_SECRET=your_app_secret_here
DROPBOX_REFRESH_TOKEN=your_refresh_token_here

# Path to the root of the audio archive on disk (local mode)
ARCHIVE_ROOT=~/Music/TMW-Archive

# SQLAlchemy connection URL — SQLite (default) or Postgres for cloud
DATABASE_URL=sqlite:///data/archive.db

# Storage backend for serving audio files: local | s3 | gcs
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=s3
# S3_BUCKET=tmw-archive
# S3_PREFIX=audio

# Required when STORAGE_BACKEND=gcs
# GCS_BUCKET=tmw-archive
# GCS_PREFIX=audio
